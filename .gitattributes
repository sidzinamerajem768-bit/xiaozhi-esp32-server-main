# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Python files
*.py text diff=python eol=lf

# Shell scripts
*.sh text eol=lf

# YAML / JSON / TOML / XML configs
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.xml text eol=lf

# Web files
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.jsx text eol=lf
*.vue text eol=lf
*.md text eol=lf
*.svg text eol=lf

# C / C++ / Header files (ESP32 firmware)
*.c text eol=lf
*.cpp text eol=lf
*.h text eol=lf
*.hpp text eol=lf
*.ino text eol=lf

# CMake / Makefile
*.cmake text eol=lf
CMakeLists.txt text eol=lf
Makefile text eol=lf

# Batch files (Windows) — keep CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files — no normalization
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.wav binary
*.mp3 binary
*.ogg binary
*.opus binary
*.pt binary
*.onnx binary
*.jit binary
*.bin binary
*.exe binary
*.dll binary
*.so binary
*.dylib binary
*.zip binary
*.tar binary
*.gz binary
*.7z binary
*.pdf binary
*.pickle binary
*.pth binary
*.safetensors binary
*.npy binary
*.npz binary
*.parquet binary
