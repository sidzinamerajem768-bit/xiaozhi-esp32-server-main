# ========================================
# 数据库配置
# 对应Java application-dev.yml的spring.datasource.druid配置
# ========================================
# 格式: mysql+pymysql://用户名:密码@主机:端口/数据库名
DATABASE_URL=mysql+pymysql://root:你的密码@127.0.0.1:3306/xiaozhi_esp32_server

# ========================================
# 认证配置
# 对应Java TokenGenerator.java和SysUserTokenServiceImpl.java
# ========================================
# JWT签名密钥 - 至少32位随机字符串
SECRET_KEY=你的密钥至少32位例如abc123def456ghi789jkl012mno345pqr678

# JWT算法 - 对应Java的Token生成方式（后续可改为MD5兼容）
ALGORITHM=HS256

# Token有效期（分钟）
# 对应Java SysUserTokenServiceImpl.java的EXPIRE = 3600 * 12 = 43200秒 = 720分钟
# 注意：Java用的是秒，这里用分钟，12小时 = 720分钟
ACCESS_TOKEN_EXPIRE_MINUTES=720